{
  "policies": {
    "DisableAppUpdate": true,
    "DefaultSerialGuardSetting": 3,
    "Preferences": {
      "zen.welcome-screen.seen": true,
      "browser.aboutwelcome.enabled": false,
      "browser.translations.neverTranslateLanguages": "en,pt,pt-BR,pt-PT"
    },
    "DontCheckDefaultBrowser": true,
    "SearchEngines": {
      "Default": "Startpage",
      "Add": [
        {
          "Name": "Startpage",
          "URLTemplate": "https://www.startpage.com/sp/search?query={searchTerms}",
          "Method": "GET",
          "IconURL": "https://www.startpage.com/favicon.ico",
          "Alias": "@sp",
          "Description": "Startpage Search"
        }
      ]
    },
    "ExtensionSettings": {
      "addon@darkreader.org": {
        "installation_mode": "normal_installed",
        "install_url": "https://addons.mozilla.org/firefox/downloads/latest/darkreader/latest.xpi"
      },
      "floccus@handmadeideas.org": {
        "installation_mode": "normal_installed",
        "install_url": "https://addons.mozilla.org/firefox/downloads/latest/floccus/latest.xpi"
      },
      "{a8332c60-5b6d-41ee-bfc8-e9bb331d34ad}": {
        "toolbar_pin": "force_pinned",
        "installation_mode": "normal_installed",
        "install_url": "https://addons.mozilla.org/firefox/downloads/latest/surfingkeys_ff/latest.xpi"
      },
      "{7be2ba16-0f1e-4d93-9ebc-5164397477a9}": {
        "toolbar_pin": "force_pinned",
        "installation_mode": "normal_installed",
        "install_url": "https://addons.mozilla.org/firefox/downloads/latest/videospeed/latest.xpi"
      }
    }
  }
}
