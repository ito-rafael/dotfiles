"group/monitoring": {
  "orientation": "inherit",
  "modules": [
    "cpu",
    "memory",
    "temperature",
    "disk",
  ]
},

"cpu": {
    "format": "<span color='#89b4fa'></span>\u2002 {usage}%",
    "tooltip": false
},

"memory": {
    "format": "<span color='#a6e3a1'></span> {used:0.1f} GiB",
    //"format": " {used:0.1f} / {total:0.1f} GiB".
},

"temperature": {
    "hwmon-path": [
        "/sys/class/hwmon/hwmon2/temp1_input",
        "/sys/devices/platform/coretemp.0/hwmon/temp1_input",
        "/sys/class/thermal/thermal_zone0/temp"
    ],
    "critical-threshold": 80,
    "format-critical": "<span color='#f9e2af'>{icon}</span> {temperatureC}°C",
    "format": "<span color='#f9e2af'>{icon}</span> {temperatureC}°C",
    "format-icons": ["", "", ""],
    "interval": 1,
},

"disk": {
    "interval": 30,
    "format": "<span color='#f38ba8'></span> {specific_free:0.1f} GB",
    "path": "/",
    "unit": "GB",
},

"group/control": {
  "orientation": "inherit",
  "modules": [
    "pulseaudio#speaker",
    "pulseaudio#microphone",
    "backlight",
    "group/gamma",
  ]
},

"pulseaudio#speaker": {
    "format": "{icon} {volume}%",
    "format-bluetooth": "{icon} {volume}%",
    "format-bluetooth-muted": " {icon}",
    //"format-muted": "",
    "format-muted": "🔇",
    "format-icons": {
        //"headphone": "",
        //"default": ["", "", ""],
        "headphone": "🎧",
        "default": ["🔈", "🔉", "🔊"],
    },
    "on-scroll-up": "wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 1%+ && ~/.config/eww/volume.sh",
    "on-scroll-down": "wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 1%- && ~/.config/eww/volume.sh",
    "reverse-scrolling": true,
    "reverse-mouse-scrolling": false,
},

"pulseaudio#microphone": {
    "format": "{format_source}",
    "format-source": " {volume}%",
    "format-source-muted": "",
    "on-scroll-up": "wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SOURCE@ 1%+",
    "on-scroll-down": "wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SOURCE@ 1%-",
    "reverse-scrolling": true,
    "reverse-mouse-scrolling": false,
},

"backlight": {
    "format": "{percent}% {icon}",
    "format-icons": ["", "", "", "", "", "", "", "", ""],
    "reverse-scrolling": true,
    "reverse-mouse-scrolling": false,
    "on-scroll-up": "~/.config/waybar/scripts/brightness.sh up",
    "on-scroll-down": "~/.config/waybar/scripts/brightness.sh down",
},

"group/gamma": {
    "orientation": "inherit",
    "modules": [
        "image#gamma-icon",
        "custom/gamma-temperature",
    ]
},

"image#gamma-icon": {
    "exec": "~/.config/waybar/scripts/gamma-icon.sh",
    //"interval": 3600,
