    "size": 14,
},

"custom/gamma-temperature": {
    "exec": "~/.config/waybar/scripts/gamma-temperature.sh",
    //"format": "🌡️ {}K",
    "format": "{}K",
    "interval": 60,
    "signal": 8,
},

"group/sysadmin": {
  "orientation": "inherit",
